{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibe-code-game-studio.dev/schemas/reporting-request-data.schema.json",
  "title": "Reporting Request Data 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "report_id", "results", "evidence", "output_ref"],
  "properties": {
    "contract_version": {"const": "1.0"},
    "report_id": {"$ref": "#/$defs/identifier"},
    "results": {
      "type": "array", "minItems": 1, "maxItems": 4999,
      "items": {"$ref": "#/$defs/result"}
    },
    "evidence": {"$ref": "#/$defs/evidence"},
    "output_ref": {"$ref": "#/$defs/reference"}
  },
  "x-vibe-runtime-validation": {
    "max_canonical_utf8_bytes": 1048576,
    "enforcement": "runtime",
    "$comment": "Draft 2020-12 cannot express canonical serialized byte length; the versioned runtime validator enforces this bound.",
    "unique_result_ids": true,
    "evidence_consistency": true,
    "output_ref_binding": "<data_dir>/production/qa/reports/<report_id>"
  },
  "$defs": {
    "identifier": {
      "type": "string", "minLength": 1, "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "reference": {
      "type": "string", "minLength": 1, "maxLength": 512,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)(?!.*\\\\)[A-Za-z0-9_-][A-Za-z0-9._-]*(?:/[A-Za-z0-9_-][A-Za-z0-9._-]*)*$"
    },
    "source_refs": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"$ref": "#/$defs/reference"}
    },
    "result": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "name", "status", "duration_ms", "source_ref"],
      "properties": {
        "id": {"$ref": "#/$defs/identifier"},
        "name": {"type": "string", "minLength": 1, "maxLength": 256},
        "status": {"enum": ["passed", "failed", "broken", "skipped", "unknown"]},
        "duration_ms": {"type": "integer", "minimum": 0},
        "source_ref": {"$ref": "#/$defs/reference"},
        "suite": {"type": "string", "minLength": 1, "maxLength": 256},
        "start_ms": {"type": "integer", "minimum": 0},
        "failure_code": {"$ref": "#/$defs/identifier"}
      }
    },
    "acceptance_criterion": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "status", "source_refs"],
      "properties": {
        "id": {"$ref": "#/$defs/identifier"},
        "status": {"enum": ["pass", "fail", "deferred"]},
        "source_refs": {"$ref": "#/$defs/source_refs"}
      }
    },
    "check": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "type", "status", "source_refs"],
      "properties": {
        "id": {"$ref": "#/$defs/identifier"},
        "type": {"$ref": "#/$defs/identifier"},
        "status": {"enum": ["pass", "fail", "deferred"]},
        "source_refs": {"$ref": "#/$defs/source_refs"}
      }
    },
    "evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["story_id", "result", "acceptance_criteria", "checks", "source_ref"],
      "properties": {
        "story_id": {"$ref": "#/$defs/identifier"},
        "result": {"enum": ["pass", "fail", "blocked"]},
        "acceptance_criteria": {
          "type": "array", "minItems": 1, "maxItems": 200,
          "items": {"$ref": "#/$defs/acceptance_criterion"}
        },
        "checks": {
          "type": "array", "minItems": 1, "maxItems": 200,
          "items": {"$ref": "#/$defs/check"}
        },
        "source_ref": {"$ref": "#/$defs/reference"}
      }
    }
  }
}
