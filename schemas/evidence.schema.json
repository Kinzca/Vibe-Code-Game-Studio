{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ccgs.dev/schemas/evidence.schema.json",
  "title": "CCGS Story Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "story_id",
    "result",
    "acceptance_criteria",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "story_id": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "enum": [
        "pass",
        "fail",
        "blocked"
      ]
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AC-[0-9]+$"
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "deferred"
            ]
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "status",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "enum": [
              "automated-test",
              "manual-test",
              "review",
              "build",
              "analysis"
            ]
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "deferred"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
