{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibe-code-game-studio.dev/schemas/upgrade-result.schema.json",
  "title": "Upgrade Result 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "plan_id", "outcome", "written", "reused", "applied_writes", "doctor", "failures"],
  "properties": {
    "contract_version": {"const": "1.0"},
    "plan_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "outcome": {"enum": ["applied", "reused", "failed"]},
    "written": {"type": "boolean"},
    "reused": {"type": "boolean"},
    "applied_writes": {"type": "array", "maxItems": 1000, "uniqueItems": true, "items": {"$ref": "#/$defs/path"}},
    "doctor": {
      "type": "object", "additionalProperties": false,
      "required": ["before_errors", "after_errors", "status"],
      "properties": {
        "before_errors": {"type": "integer", "minimum": 0},
        "after_errors": {"type": "integer", "minimum": 0},
        "status": {"enum": ["pass", "failed", "rolled-back"]}
      }
    },
    "failures": {
      "type": "array", "maxItems": 100,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["code", "message", "retryable"],
        "properties": {
          "code": {"type": "string", "minLength": 1, "maxLength": 128},
          "message": {"type": "string", "minLength": 1, "maxLength": 512},
          "retryable": {"const": false}
        }
      }
    }
  },
  "$defs": {
    "path": {"type": "string", "minLength": 1, "maxLength": 512, "pattern": "^(?!.*(?:^|/)\\.{1,2}(?:/|$))[A-Za-z0-9_.-]+(?:/[A-Za-z0-9_.-]+)*$"}
  }
}
