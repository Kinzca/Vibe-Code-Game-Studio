{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibe-code-game-studio.dev/schemas/replay-record.schema.json",
  "title": "Replay Record Contract 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "event_id",
    "run_id",
    "input_fingerprint",
    "plan_id",
    "attempt",
    "status",
    "failure_class",
    "result"
  ],
  "properties": {
    "contract_version": {
      "const": "1.0"
    },
    "event_id": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "input_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "plan_id": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "attempt": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "status": {
      "enum": [
        "succeeded",
        "failed"
      ]
    },
    "failure_class": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "enum": [
            "transient_transport_failure",
            "declared_worker_unavailable",
            "business_failure",
            "configuration_error",
            "schema_error",
            "policy_rejected",
            "path_error"
          ]
        }
      ]
    },
    "result": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "succeeded"
          }
        }
      },
      "then": {
        "properties": {
          "failure_class": {
            "type": "null"
          }
        }
      },
      "else": {
        "properties": {
          "failure_class": {
            "enum": [
              "transient_transport_failure",
              "declared_worker_unavailable",
              "business_failure",
              "configuration_error",
              "schema_error",
              "policy_rejected",
              "path_error"
            ]
          }
        }
      }
    }
  ]
}
