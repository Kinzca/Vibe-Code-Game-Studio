{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibe-code-game-studio.dev/schemas/retrieval-request-data.schema.json",
  "title": "Retrieval Request Data Contract 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["query", "source_ids", "limit", "min_score"],
  "properties": {
    "query": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "source_ids": {
      "type": "array", "minItems": 1, "maxItems": 100, "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 128,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" }
    },
    "limit": { "type": "integer", "minimum": 1, "maximum": 50 },
    "min_score": { "type": "number", "minimum": -1, "maximum": 1 }
  },
  "x-vibe-runtime-validation": {
    "finite_numbers": true,
    "trimmed_query": true,
    "declared_source_ids": true,
    "sensitive_payload_rules": "1.0"
  }
}
