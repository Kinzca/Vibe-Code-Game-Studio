{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ccgs.dev/schemas/automated-test-results.schema.json",
  "title": "CCGS Automated Test Results",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tests"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "suite": {
            "type": "string"
          },
          "package": {
            "type": "string"
          },
          "status": {
            "enum": [
              "pass",
              "passed",
              "fail",
              "failed",
              "error",
              "broken",
              "skip",
              "skipped",
              "deferred",
              "unknown"
            ]
          },
          "duration_ms": {
            "type": "integer",
            "minimum": 0
          },
          "start_ms": {
            "type": "integer",
            "minimum": 0
          },
          "message": {
            "type": "string"
          },
          "trace": {
            "type": "string"
          },
          "stdout": {
            "type": "string"
          },
          "stderr": {
            "type": "string"
          }
        }
      }
    }
  }
}
